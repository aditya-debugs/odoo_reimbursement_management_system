DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Optional: vision LLM after Tesseract (receipt images are sent to the provider).
# Prefer Groq when GROQ_API_KEY is set; override with OCR_AI_PROVIDER=openai|groq
# GROQ_API_KEY=gsk_...
# OCR_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OPENAI_API_KEY=sk-...
# OCR_AI_MODEL=gpt-4o-mini
# OCR_AI_DISABLED=true
